FROM node:20-alpine

RUN corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /app

# 1. Copy root package files, patches, and install (builds tiptap-apcore)
COPY package.json pnpm-lock.yaml ./
COPY patches/ ./patches/
COPY src/ ./src/
COPY tsconfig.json ./

RUN pnpm install --frozen-lockfile && pnpm run build

# 2. Copy frontend package files and install
#    "tiptap-apcore": "file:../.." resolves to /app
COPY examples/demo/frontend/package.json examples/demo/frontend/pnpm-lock.yaml ./demo/frontend/
WORKDIR /app/demo/frontend
RUN pnpm install --frozen-lockfile

# 3. Copy frontend source
COPY examples/demo/frontend/src/ ./src/
COPY examples/demo/frontend/tsconfig.json ./
COPY examples/demo/frontend/vite.config.ts ./
COPY examples/demo/frontend/index.html ./

EXPOSE 5173

CMD ["pnpm", "run", "dev", "--", "--host", "0.0.0.0"]
