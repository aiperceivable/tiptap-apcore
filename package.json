{
  "name": "tiptap-apcore",
  "version": "0.4.0",
  "description": "TipTap editor APCore modules - let AI safely control your TipTap editor",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@tiptap/core": "^2.0.0",
    "apcore-js": ">=0.25.0",
    "apcore-mcp": "^0.17.0"
  },
  "devDependencies": {
    "@tiptap/core": "^2.10.0",
    "@tiptap/pm": "^2.10.0",
    "@tiptap/starter-kit": "^2.10.0",
    "@vitest/coverage-v8": "^3.0.0",
    "apcore-js": "^0.25.0",
    "apcore-mcp": "^0.17.0",
    "apdev-js": "^0.2.2",
    "jsdom": "^25.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "Apache-2.0",
  "apdev": {
    "base_package": "tiptap-apcore"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "tiptap",
    "apcore",
    "apcore-mcp",
    "mcp",
    "ai",
    "editor",
    "model-context-protocol",
    "rich-text",
    "prosemirror"
  ],
  "author": "aiperceivable",
  "homepage": "https://aiperceivable.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/aiperceivable/tiptap-apcore.git"
  },
  "bugs": {
    "url": "https://github.com/aiperceivable/tiptap-apcore/issues"
  }
}